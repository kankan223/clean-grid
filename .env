# =============================================================================
# CleanGrid Environment Variables
# =============================================================================
# Copy this file to .env and fill in your actual values
# Never commit .env to version control

# =============================================================================
# Security Keys
# =============================================================================
# Generate with: openssl rand -hex 32
JWT_SECRET_KEY=60a5554b15da5cdbe65355bcbe035ad2349e72825165be69820581d26d266f32

# =============================================================================
# External API Keys
# =============================================================================
# OpenRouteService API Key for route optimization
# Get free key at: https://openrouteservice.org/dev/#/signup
ORS_API_KEY=your-openrouteservice-api-key-here

# =============================================================================
# Cloudflare R2 Storage (Image Storage)
# =============================================================================
# R2 Endpoint URL (e.g., https://your-account.r2.cloudflarestorage.com)
R2_ENDPOINT_URL=your-r2-endpoint-url-here

# R2 Access Key ID
R2_ACCESS_KEY_ID=your-r2-access-key-id-here

# R2 Secret Access Key
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key-here

# R2 Bucket Name
R2_BUCKET_NAME=cleangrid-images

# =============================================================================
# Development Settings
# =============================================================================
# Frontend URL for CORS
FRONTEND_URL=http://localhost:3000

# Backend URL for frontend API calls
BACKEND_URL=http://localhost:8000

# AI Service URL
AI_SERVICE_URL=http://localhost:8001

# =============================================================================
# Optional: Production Settings
# =============================================================================
# Production Frontend URL (Vercel)
# FRONTEND_URL=https://cleangrid.vercel.app

# Production Backend URL (Railway)
# BACKEND_URL=https://cleangrid-backend.railway.app

# Production AI Service URL (Railway)
# AI_SERVICE_URL=https://cleangrid-ai.railway.app

# =============================================================================
# Database Settings (for local development)
# =============================================================================
# These are hardcoded in docker-compose.yml for development
# DATABASE_URL=postgresql+asyncpg://cleangrid:cleangrid@localhost:5432/cleangrid
# REDIS_URL=redis://localhost:6379/0
