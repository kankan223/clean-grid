# =============================================================================
# CleanGrid AI Service Environment Variables
# =============================================================================
# Copy this file to .env and fill in your actual values
# Never commit .env to version control

# =============================================================================
# YOLO Model Configuration
# =============================================================================
# Path to YOLO model file (relative to container)
YOLO_MODEL_PATH=/app/models/yolov8n.pt

# Confidence threshold for waste detection (0.0 - 1.0)
YOLO_CONFIDENCE_THRESHOLD=0.45

# =============================================================================
# Detection Classes
# =============================================================================
# Comma-separated list of COCO classes to consider as waste
RELEVANT_CLASSES=bottle,cup,bag,banana,can,backpack,suitcase

# =============================================================================
# File Upload Settings
# =============================================================================
# Maximum image size in bytes (10MB = 10485760)
MAX_IMAGE_SIZE=10485760

# Allowed image extensions (comma-separated)
ALLOWED_EXTENSIONS=jpg,jpeg,png,webp

# =============================================================================
# Service Configuration
# =============================================================================
# Port for the AI service
AI_SERVICE_PORT=8001

# Host binding (0.0.0.0 for Docker)
AI_SERVICE_HOST=0.0.0.0

# Log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# =============================================================================
# Performance Settings
# =============================================================================
# Image resize dimensions for inference (width,height)
INFERENCE_IMAGE_SIZE=640,640

# Maximum concurrent inference requests
MAX_CONCURRENT_REQUESTS=4

# =============================================================================
# Optional: Model Download Settings
# =============================================================================
# Auto-download model if not found (true/false)
AUTO_DOWNLOAD_MODEL=true

# Model download URL (Ultralytics default)
MODEL_DOWNLOAD_URL=https://github.com/ultralytics/assets/releases/download/v0.0.0/yolov8n.pt
