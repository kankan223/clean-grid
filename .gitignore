# -----------------------------------------------------------------------------
# CleanGrid monorepo .gitignore
# Stack coverage: Next.js/Node.js frontend + Python/FastAPI backend + AI service
# -----------------------------------------------------------------------------

# -----------------------------------------------------------------------------
# Dependencies
# -----------------------------------------------------------------------------
**/node_modules/
**/.pnp/
.pnp.js
**/.yarn/*
!.yarn/patches/
!.yarn/plugins/
!.yarn/releases/
!.yarn/sdks/
!.yarn/versions/

# Python virtual environments
**/.venv/
**/venv/
**/ENV/
**/env/

# -----------------------------------------------------------------------------
# Build, cache, and test artifacts
# -----------------------------------------------------------------------------

# Next.js / frontend build outputs
**/.next/
**/out/
**/build/
**/dist/
**/.turbo/
**/.vercel/
*.tsbuildinfo
next-env.d.ts

# Coverage and test reports
**/coverage/
**/.coverage
**/.coverage.*
**/htmlcov/
**/.pytest_cache/
**/.hypothesis/
**/.tox/
**/.nox/
**/.mypy_cache/
**/.ruff_cache/

# Python bytecode
**/__pycache__/*
**/*.py[cod]
**/*$py.class

# Generic caches/temp files
**/.cache/
**/.temp/
**/tmp/
*.tmp

# -----------------------------------------------------------------------------
# Environment and secrets
# -----------------------------------------------------------------------------
.env
.env.*
**/.env
**/.env.*
*.env
*.env.*
*.local

# Keep template/example env files tracked
!.env.example
!**/.env.example
!*.env.example

# Keys/certs and secret-like files
*.pem
*.key
*.crt
*.p12

# -----------------------------------------------------------------------------
# Logs and runtime files
# -----------------------------------------------------------------------------
*.log
logs/
**/logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# -----------------------------------------------------------------------------
# IDE/editor configuration
# -----------------------------------------------------------------------------
.vscode/
.idea/
*.iml
*.suo
*.user
*.userossc
*.sln.docstates
*.swp
*.swo
*~

# -----------------------------------------------------------------------------
# OS-specific files
# -----------------------------------------------------------------------------
.DS_Store
Thumbs.db
Desktop.ini
$RECYCLE.BIN/

# -----------------------------------------------------------------------------
# Project-specific custom ignores
# -----------------------------------------------------------------------------
temp-data/
**/temp-data/
